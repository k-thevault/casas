{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/api/casas",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ],
  "crons": [
    {
      "path": "/api/vigia-diaria",
      "schedule": "0 11 * * *"
    }
  ],
  "functions": {
    "api/vigia-diaria.js": {
      "maxDuration": 60
    }
  }
}
